# CarbonSense — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ── Database (TimescaleDB) ──────────────────────────────────────────
DATABASE_URL=postgresql://carbonsense:changeme@localhost:5432/carbonsense
DATABASE_POOL_SIZE=10

# ── Kafka / Event Backbone ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_DATA_ARRIVED=building.data.arrived

# ── Temporal ────────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=carbonsense
TEMPORAL_TASK_QUEUE=analysis-pipeline

# ── MLflow Model Registry ──────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Object Storage (S3-compatible) ─────────────────────────────────
S3_BUCKET_NAME=carbonsense-artifacts
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme

# ── API / Auth ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ── LLM (Reporting Service) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGEME

# ── Observability ───────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# ── External Data Providers (abstracted interfaces) ─────────────────
WEATHER_PROVIDER_API_KEY=changeme
SOLAR_PROVIDER_API_KEY=changeme
CARBON_INTENSITY_PROVIDER_API_KEY=changeme